# Database
# For local development (without Docker):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grupo_gestor
# For Docker Compose:
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/grupo_gestor
# For Neon (production):
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/grupo_gestor?sslmode=require

# Payload CMS Secret (minimum 32 characters)
PAYLOAD_SECRET=your-super-secret-key-minimum-32-characters

# Next.js
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Environment
NODE_ENV=development
