# Production Environment Variables Template
# Copy this file to .env and fill in the values

# PostgreSQL Database Connection String
# For Neon (recommended):
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/grupo_gestor?sslmode=require
# For Supabase:
# DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
# For VPS-hosted PostgreSQL:
# DATABASE_URL=postgresql://grupo_gestor_user:password@localhost:5432/grupo_gestor

# Payload CMS Secret (REQUIRED - minimum 32 characters, use strong random string)
PAYLOAD_SECRET=

# Public URL (REQUIRED - your domain)
NEXT_PUBLIC_SERVER_URL=https://your-domain.com

# Optional: Email Service (if implementing password reset)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
